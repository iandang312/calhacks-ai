# Copy this file to `local.properties` and fill in your key.
# Android Studio also writes `sdk.dir` here automatically — keep that line if present.
# local.properties is gitignored, so your key stays out of version control.

# Deepgram powers both speech-to-text and text-to-speech (Aura).
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# Optional Aura TTS voice; leave blank for the default "aura-asteria-en".
DEEPGRAM_TTS_MODEL=

# Base URL of the backend intent service (backend/intent_service). Leave blank for
# the default http://10.0.2.2:8000 — the emulator's route to the host machine.
# For a physical device, use the host's LAN IP (e.g. http://192.168.1.20:8000).
INTENT_SERVICE_URL=
